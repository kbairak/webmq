    "webmq-frontend": "1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "vite": "^7.1.5"
